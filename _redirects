# Cloudflare Pages serves clean URLs natively (e.g. privacy.html at /privacy).
# A "/x /x.html 200" rule for a single-segment path collides with that native
# canonicalization and produces an infinite 308 redirect loop, so those paths
# intentionally have NO rule here — /privacy /terms /contact /apps resolve natively.

# Alias for the app policy hub.
/policies  /apps  302

# Per-app policy clean URLs (nested paths have no native 1:1 file mapping).
/apps/s-partner/privacy         /s-partner-privacy.html         200
/apps/s-partner/terms           /s-partner-terms.html           200
/apps/s-partner/delete-account  /s-partner-delete-account.html  200
/apps/mbti/privacy        /mbti-privacy.html         200
/apps/mbti/terms          /mbti-terms.html           200

# MBTIcards account deletion (Google Play / App Store deletion URL).
# Several slug spellings all resolve to the same page so the URL submitted to
# the stores keeps working regardless of which form is referenced.
/apps/mbticards/delete-account    /mbticards-delete-account.html    200
/apps/mbti-cards/delete-account   /mbticards-delete-account.html    200
/apps/mbti/delete-account         /mbticards-delete-account.html    200
